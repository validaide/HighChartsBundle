{
  "name": "validaide/highchartsbundle",
  "license": "MIT",
  "type": "symfony-bundle",
  "description": "HighCharts integration for your Symfony3 project.",
  "keywords": [
    "highcharts",
    "symfony",
    "bundle"
  ],
  "authors": [
    {
      "name": "Marcel Tuinstra",
      "email": "marcel.tuinstra@validaide.com"
    },
    {
      "name": "Mark Bijl",
      "email": "mark.bijl@validaide.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Validaide\\HighChartsBundle\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Validaide\\HighChartsBundle\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "platform": {
      "php": "7.2.13"
    }
  },
  "require": {
    "php": "7.2.*",
    "ext-json": "*",
    "symfony/config": "^4.0",
    "symfony/dependency-injection": "^4.0",
    "symfony/http-kernel": "^4.0",
    "symfony/options-resolver": "^4.0",
    "symfony/process": "^4.0",
    "symfony/serializer": "^4.0",
    "symfony/templating": "^4.0",
    "symfony/twig-bundle": "~4.0",
    "symfony/yaml": "^4.0",
    "validaide/html-builder": "dev-chore/symfony-4"
  },
  "require-dev": {
    "brianium/paratest": "^3.0",
    "phpunit/phpunit": "^8.0",
    "symfony/phpunit-bridge": "^4.0"
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/validaide/HighChartsBundle.git"
    },
    {
      "type": "vcs",
      "url": "https://github.com/validaide/common.git",
      "no-api": true
    },
    {
      "type": "vcs",
      "url": "https://github.com/validaide/html-builder.git",
      "no-api": true
    }
  ]
}
